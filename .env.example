# --- Core ---
GEMINI_API_KEY=your-gemini-api-key
DATABASE_URL=postgresql+asyncpg://rule:rule@postgres:5432/ruledb

# --- LLM Provider Abstraction (RR-010) ---
LLM_PROVIDER_PRIMARY=gemini
LLM_PROVIDER_FALLBACK=
LLM_PROVIDER_SELF_HOSTED_URL=
LLM_PROVIDER_SELF_HOSTED_API_KEY=
LLM_TENANT_OVERRIDES={}
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Tier toggles (set to true to enable optional services) ---
ELASTICSEARCH_ENABLED=false
NEO4J_ENABLED=false
REDIS_ENABLED=false
MCP_ENABLED=false

# --- Elasticsearch ---
ELASTICSEARCH_URL=http://elasticsearch:9200

# --- Neo4j ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ruledev1
RULEREPO_SERVER_URL=http://server:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO
LLM_DEFAULT_MODEL=gemini-3-flash-preview
LLM_JUDGE_MODEL=gemini-3.1-pro-preview
CORS_ORIGINS=["http://localhost:3000"]
AUTH_REQUIRED=false

# --- MCP Server ---
MCP_TRANSPORT=stdio
MCP_PORT=8001
MCP_API_KEY=

# --- Gateway ---
GATEWAY_SKIP_VERIFICATION=false

# --- Redis / arq ---
REDIS_URL=redis://redis:6379/0

# --- GitHub App ---
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# --- Intelligence ---
INTELLIGENCE_HEALTH_CRON="0 2 * * *"
INTELLIGENCE_DRIFT_CRON="0 3 * * *"
INTELLIGENCE_MAX_SIMULATION_REPLAYS=100

# --- Alerts ---
ALERT_WEBHOOK_URL=                   # URL to receive critical alert webhooks

# --- Weekly Digest ---
DIGEST_WEBHOOK_URL=                  # URL to receive weekly governance digest (Slack, email, etc.)

# --- Notifications (Phase 6a: Collaborative Governance) ---
NOTIFICATION_WEBHOOK_URL=            # Slack/Teams incoming webhook for proposal notifications
NOTIFICATION_WEBHOOK_TYPE=slack      # slack, teams, or generic

# --- Audit WORM (RR-011: Audit Export & Retention) ---
AUDIT_WORM_ENABLED=false
AUDIT_WORM_S3_BUCKET=
AUDIT_WORM_S3_REGION=

# --- Domain Packs (Phase 8+) ---
ENABLED_PACKS=code,contract,hr_attendance,communication,expense,legal,sales,it_security,governance
DEFAULT_PERSONA=admin
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,ja

# --- Agent Governance (Phase 6b: Autonomous Agent Governance) ---
AGENT_TRUST_PROMOTION_ENABLED=true
AGENT_MASTERY_THRESHOLD=50           # Consecutive passes to mark rule mastery
AGENT_PATTERN_MIN_EVIDENCE=10        # Min evidence count for pattern reports

# --- Cross-Organizational Direction (Phase 7) ---
CROSS_ORG_FEATURES_ENABLED=true
DEPARTMENT_RBAC_ENABLED=true
ASSISTANT_ENABLED=true
COMPLIANCE_COCKPIT_ENABLED=true
POLYGLOT_VERIFICATION_ENABLED=true

# --- Opt-in Features (default OFF) ---
MULTI_AGENT_SESSIONS_ENABLED=false
GITHUB_APP_ENABLED=false

# --- Frozen Features (Phase 6 freeze — default OFF) ---
# Gateway/Connectors: webhook ingestion, policy engine, normalizers
GATEWAY_ENABLED=false
NEXT_PUBLIC_GATEWAY_ENABLED=false
# Advanced Observability: digest delivery, agent analytics, effectiveness scoring, cross-project comparison
ADVANCED_OBSERVABILITY_ENABLED=false
NEXT_PUBLIC_ADVANCED_OBSERVABILITY_ENABLED=false

# --- Alert / Digest Delivery ---
ALERT_OUTPUT_MODE=local              # "local" | "webhook" | "both"
DIGEST_OUTPUT_MODE=local             # "local" | "webhook" | "both"

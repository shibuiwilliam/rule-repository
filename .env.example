# --- Core ---
GEMINI_API_KEY=your-gemini-api-key
DATABASE_URL=postgresql+asyncpg://rule:rule@postgres:5432/ruledb
ELASTICSEARCH_URL=http://elasticsearch:9200
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ruledev
RULEREPO_SERVER_URL=http://server:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO
LLM_DEFAULT_MODEL=gemini-3-flash-preview
LLM_JUDGE_MODEL=gemini-3.1-pro-preview
CORS_ORIGINS=["http://localhost:3000"]
AUTH_REQUIRED=false

# --- MCP Server ---
MCP_TRANSPORT=stdio
MCP_PORT=8001
MCP_API_KEY=

# --- Gateway ---
GATEWAY_SKIP_VERIFICATION=false

# --- Redis / arq ---
REDIS_URL=redis://redis:6379/0

# --- GitHub App ---
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# --- Slack ---
SLACK_SIGNING_SECRET=

# --- Intelligence ---
INTELLIGENCE_HEALTH_CRON=0 2 * * *
INTELLIGENCE_DRIFT_CRON=0 3 * * *
INTELLIGENCE_MAX_SIMULATION_REPLAYS=100

# --- Alerts ---
ALERT_WEBHOOK_URL=                   # URL to receive critical alert webhooks

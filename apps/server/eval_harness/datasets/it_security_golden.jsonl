{"id": "sec-001", "domain": "it_security", "artifact_type": "iac_plan", "input_payload": {"plan_format": "terraform", "resources": [{"type": "aws_s3_bucket", "name": "public-data-bucket", "action": "create", "properties": {"acl": "public-read", "versioning": false}}], "tags": {}, "encryption": null}, "expected_verdict": "DENY", "tags": ["iac", "s3", "public-access"], "description": "IaC plan with public S3 bucket and no encryption"}
{"id": "sec-002", "domain": "it_security", "artifact_type": "iac_plan", "input_payload": {"plan_format": "terraform", "resources": [{"type": "aws_ebs_volume", "name": "app-data-vol", "action": "create", "properties": {"encrypted": true, "kms_key_id": "arn:aws:kms:us-east-1:123456789:key/abc-123", "size_gb": 100}}], "tags": {"owner": "platform-team", "environment": "production", "cost-center": "eng-001"}}, "expected_verdict": "ALLOW", "tags": ["iac", "ebs", "encrypted"], "description": "IaC plan with encrypted EBS volumes and proper tags"}
{"id": "sec-003", "domain": "it_security", "artifact_type": "iac_plan", "input_payload": {"plan_format": "terraform", "resources": [{"type": "aws_iam_policy", "name": "admin-all-access", "action": "create"}], "iam_policies": [{"name": "admin-all-access", "statements": [{"effect": "Allow", "actions": ["*"], "resources": ["*"]}]}], "tags": {"owner": "dev-team"}}, "expected_verdict": "DENY", "tags": ["iac", "iam", "wildcard-policy"], "description": "IaC plan with wildcard IAM policy granting full access"}
{"id": "sec-004", "domain": "it_security", "artifact_type": "iac_plan", "input_payload": {"plan_format": "cloudformation", "resources": [{"type": "AWS::EC2::Instance", "name": "web-server-01", "action": "create", "properties": {"instance_type": "t3.medium", "monitoring": true}}, {"type": "AWS::RDS::DBInstance", "name": "app-db", "action": "create", "properties": {"encrypted": true, "multi_az": true}}], "tags": {"owner": "backend-team", "environment": "production", "cost-center": "be-002", "data-classification": "internal"}}, "expected_verdict": "ALLOW", "tags": ["iac", "cloudformation", "tagged"], "description": "IaC plan with properly tagged resources and encrypted RDS"}
